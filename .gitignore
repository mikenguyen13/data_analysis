installed.csv

# Bookdown leaves chapter-by-chapter intermediate .md and .html files
# at the repo root when run with clean=FALSE. Ignore them at root only
# (so README.md, _banner.html, google_analytics.html, m1or.htm stay tracked).
/[0-9]*.md
/[0-9]*.html
/[a-z]*.html
/[a-z]*.md
/index.html
/index.md
/render*.rds
!/README.md
!/google_analytics.html

